{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreExportsUsedInFile": true,
  "entry": ["scripts/**/*.{ts,mjs}"],
  "next": {
    "entry": [
      "next.config.{js,ts,mjs,cjs}",
      "{app,pages}/**/*.{js,jsx,ts,tsx}",
      "proxy.{js,ts}",
      "middleware.{js,ts}"
    ]
  },
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "proxy.{ts,js}",
    "scripts/**/*.{ts,tsx,mjs,js}"
  ],
  "ignore": [
    "components/admin/editors/index.ts",
    "components/admin/forms/index.ts",
    "components/admin/layout/index.ts",
    "components/blogs/index.ts",
    "components/command-palette/index.ts",
    "components/layout/index.ts",
    "lib/content/index.ts",
    "lib/hooks/index.ts"
  ]
}
